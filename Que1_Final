    }
    for(int i=0;i<n;i++){
        Request key=arr[i];
        int j=i-1;
        while(j>=0 && ((arr[j].priority>key.priority) || (arr[j].priority==key.priority && arr[j].time>key.time))){
            arr[j+1]=arr[j];
            j--;
        }
        arr[j+1]=key;
    }
    stack s(n);
    queue q(n);
    dll dll;
    ht ht;
    bst bst;
    cout<<endl<<"SORTED REQUESTS :"<<endl;
    for(int i=0;i<n;i++){
        cout<<arr[i].reqID<<" "<<arr[i].priority<<" "<<arr[i].time<<endl;
        if(arr[i].priority==1){
            s.push(arr[i].reqID);
        }
        else{
            q.enqueue(arr[i].reqID);
        }
    }
    int trace[n];
    int i=0;
    cout<<endl<<"PROCESSING TRACE :"<<endl;
    while(!s.isEmpty() || !q.isEmpty()){
            if(!s.isEmpty()){
            int process=s.pop();
            trace[i]=process;
            cout<<"Process : "<<process<<"  | Stack : ";
            s.print();
            cout<<" | Queue : ";
            q.print();
            cout<<endl;
        }
        else{
            int process=q.dequeue();
            trace[i]=process;
            cout<<"Process : "<<process<<"  | Stack : ";
            s.print();
            cout<<" | Queue : ";
            q.print();
            cout<<endl;
        }
        i++;
        }
    for(int i=0;i<n;i++){
        dll.insertTail(trace[i]);
        ht.insert(trace[i]);
        bst.root=bst.insert(bst.root,trace[i]);
    }
    dll.display();
    dll.deleteByID();
    ht.search();
    ht.print();
    ht.deleteById(102);
    bst.print();
}
