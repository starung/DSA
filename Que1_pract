class stack{
    public:
    int* arr;
    int top;
    int space;

    stack(int s){
        space=s;
        arr=new int[space];
        top=-1;
    }

    bool isEmpty(){
        return top==-1;
    }
    bool isFull(){
        return top==space-1;
    }
    void push(int data){
        if(isFull()){
            cout<<"Stack is Full"<<endl;
        }
        else{
            arr[++top]=data;
        }
    }
    int pop(){
        if(isEmpty()){
            cout<<"Stack is Empty"<<endl;
        }
        else{
            return arr[top--];
        }
    }
    
    void print(){
        if(isEmpty()){
            cout<<"Stack is Empty"<<endl;
        }
        else{
            for(int i=top;i>=0;i--){
                cout<<arr[i]<<" ";
            }
            cout<<endl;
        }
    }

};

class queue{
    public:
    int*arr;
    int front;
    int top;
    int size;

    queue(int s){
        size=s;
        arr=new int[size];
        front=top=-1;
    }

    bool isEmpty(){
        return front==-1 || front>top;
    }

    bool isFull(){
        return top==size-1;
    }

    void enqueue(int data){
        if(isFull()){
            cout<<"Queue is Full"<<endl;
        }
        else if(isEmpty()){
            front=0;
        }

        arr[++top]=data;
    }

    int dequeue(){
        if(isEmpty()){
            cout<<"Queue is empty"<<endl;
        }
        else{
            return arr[front++];
        }
    }

    void print(){
        if(isEmpty()){
            cout<<"Queue is Empty"<<endl;
        }
        else{
            for(int i=front;i<=top;i++){
                cout<<arr[i]<<" ";
            }
            cout<<endl;
        }
    }
};

class DLLNode{
    public:
    int data;
    DLLNode*left;
    DLLNode*right;

    DLLNode(int d){
        data=d;
        left=right=NULL;
    }

};

class DLL{
    public:
    DLLNode* head;
    DLLNode* tail;

    DLL(){
        head=tail=NULL;
    }

    void insertTail(int d){
        DLLNode* newNode=new DLLNode(d);
        if(head==NULL){
            head=tail=newNode;
        }
        else{
            tail->right=newNode;
            newNode->left=tail;
            tail=newNode;
        }

    }

    void deleteById(int id){
        DLLNode*temp=head;
        
        while(temp!=NULL && temp->data!=id){
            temp=temp->right;
        }
        
        if(temp==NULL){
            return;
        }

        if(temp->right!=NULL){
            temp->right->left=temp->left;
        }
        else{
            tail=tail->left;
        }
        if(temp->left!=NULL){
            temp->left->right=temp->right;
        }
        else{
            head=head->right;
        }

    
        delete temp;

    }

    void forwardPrint(DLLNode* head){
            if(head==NULL){
                cout<<"DLL is Empty";
            }
            else{
                DLLNode* temp=head;
                while(temp!=NULL){
                    cout<<temp->data<<" ";
                    temp=temp->right;
                }
            }
        }

    void BackwardPrint(DLLNode* tail){
            if(head==NULL){
                cout<<"DLL is Empty";
            }
            else{
                DLLNode* temp=tail;
                while(temp!=NULL){
                    cout<<temp->data<<" ";
                    temp=temp->left;
                }
            }
        }


    void print(){
        void forwardPrint(DLLNode* head);
        cout<<endl;
        void BackwardPrint(DLLNode* tail);
    }

};

class htNode{
    public:
    int status;
    int reqId;

    htNode(){
        reqId=-1;
        status=0 ; // 1-occupied 2-delete 0-empty
    }
};

class ht{
    public:
    htNode*table;
    int size;

    ht(){
        size=10;
        table=new htNode[size];
    }

    void insert(int id){
        int index=id%size;
        while(table[index].status==1){
            index=(index+1)%size;
        }
        table[index].reqId=id;    
        table[index].status=1;    
    }
    void print(){
        cout << endl<<"--- Hash Table ---" << endl;
        for(int i=0;i<size;i++){
            cout << "[" << i << "]: ";
            if(table[i].status==1){
                cout<<table[i].reqId;
            }
            else if(table[i].status==2){
                cout<<"Deleted";
            }
            else if(table[i].status==0){
                cout<<"Empty";
            }
            cout<<endl;
        }
    }

    void search(int key){
        int index=key%size;
        int probes=1;
        int start=index;
        while(table[index].status!=0){
            if(table[index].status==1 && table[index].reqId==key){
                cout<<"Key : "<<key<<" Found at : "<<index<<" Probes : "<<probes<<endl;
                break;
            }
            probes++;
            index=(index+1)%size;

            if(index==start){
                break;
            }
        }
        cout<<"Search "<<key<<": Not Found , Probes: "<<probes<<endl;
    }

    void deleteById(int id){
        int index=id%size;
        int start=index;
        while(table[index].status!=0){
            if(table[index].status==1 && table[index].reqId==id){
                table[index].status=2;
                cout<<"deleted : "<<id<<endl;
                return;
            }
            index=(index+1)%size;

            if(index==start){
                break;
            }
        }
        cout<<"Not Found"<<endl;
    }
    
};

class bstNode{
    public:
    int reqID;
    bstNode*left;
    bstNode*right;

    bstNode(int d){
        reqID=d;
        left=right=NULL;
    }
};
class bst{
    public:
    bstNode* root;

    bst(){
        root=NULL;
    }
    bstNode* insert(bstNode* root,int d){
        if(root==NULL){
            bstNode*newNode=new bstNode(d);
            root=newNode;
            return newNode;    //
        }
        else if(root->reqID>d){
            root->left=insert(root->left,d);
        }
        else{
            root->right=insert(root->right,d);
        }
        return root;   //
    }
    void preorder(bstNode*root){
        if(root==NULL){
            return;
        }
        else{
            cout<<root->reqID;
            cout<<" ";
            preorder(root->left);
            cout<<" ";
            preorder(root->right);
        }
    }
    void inorder(bstNode*root){
        if(root==NULL){
            return;
        }
        else{
            inorder(root->left);
            cout<<" ";
            cout<<root->reqID;
            cout<<" ";
            inorder(root->right);
        }
    }
    void postorder(bstNode*root){
        if(root==NULL){
            return;
        }
        else{
            postorder(root->left);
            cout<<" ";
            postorder(root->right);
            cout<<" ";
            cout<<root->reqID;
        }
    }
    void print(){
        cout<<"Preorder | ";
        preorder(root);
        cout<<endl;
        cout<<"Inorder | ";
        inorder(root);
        cout<<endl;
        cout<<"Postorder | ";
        postorder(root);
    }
};

